{
  "name": "pothys-backend",
  "version": "0.0.1",
  "description": "",
  "author": "riyaz ahmed",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"apps/**/*.ts\" \"libs/**/src/**/*.ts\" --fix --max-warnings 0 --cache",
    "lint:check": "eslint \"apps/**/*.ts\" \"libs/**/src/**/*.ts\" --max-warnings 0 --cache",
    "tsc:check": "tsc --noEmit --project tsconfig.base.json",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\" --ignore-path .prettierignore",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "build": "pnpm run build:libs && pnpm run build:services",
    "build:services": "pnpm --filter './apps/*' run build",
    "bootstrap": "pnpm install && pnpm run build:libs && pnpm --filter ./microservices/... run build",
    "build:libs": "pnpm --filter libs build:all",
    "stop:all": "docker-compose down",
    "clean:all": "find . -type d \\( -name 'node_modules' -o -name 'dist' -o -name 'pnpm-lock.yaml' \\) -prune -exec rm -rf '{}' +",
    "start:all": "pnpm run bootstrap && docker-compose up -d",
    "start:identity-service": "pnpm run bootstrap && docker-compose up identity-service",
    "start:cms-service": "pnpm run bootstrap && docker-compose up cms-service",
    "start:portfolio-service": "pnpm run bootstrap && docker-compose up portfolio-service",
    "start:payment-service": "pnpm run bootstrap && docker-compose up payment-service",
    "start:transaction-service": "pnpm run bootstrap && docker-compose up transaction-service"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@aws-sdk/lib-storage": "^3.658.1",
    "@aws-sdk/s3-request-presigner": "^3.658.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.1",
    "@pothys/api-client": "workspace:*",
    "@pothys/auth": "workspace:*",
    "@pothys/config": "workspace:*",
    "@pothys/core": "workspace:*",
    "@pothys/db-base": "workspace:*",
    "@pothys/logger": "workspace:*",
    "@pothys/swagger-base": "workspace:*",
    "@pothys/type-kit": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.19",
    "exceljs": "^4.4.0",
    "fast-csv": "^5.0.2",
    "fast-xml-parser": "^4.5.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "jszip": "^3.10.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.2",
    "pdf-lib": "^1.17.1",
    "puppeteer": "24.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/moment-timezone": "^0.5.30",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.7.3"
    }
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
